{"ast":null,"code":"import{useState,useEffect}from'react';export const useScrollPosition=()=>{const[scrollPosition,setScrollPosition]=useState(0);const[isScrolled,setIsScrolled]=useState(false);useEffect(()=>{const handleScroll=()=>{const position=window.scrollY;setScrollPosition(position);setIsScrolled(position>50);};window.addEventListener('scroll',handleScroll,{passive:true});handleScroll();return()=>window.removeEventListener('scroll',handleScroll);},[]);return{scrollPosition,isScrolled};};export default useScrollPosition;","map":{"version":3,"names":["useState","useEffect","useScrollPosition","scrollPosition","setScrollPosition","isScrolled","setIsScrolled","handleScroll","position","window","scrollY","addEventListener","passive","removeEventListener"],"sources":["/Users/zackyviriot/mgt-fashion/MGT SITES/Where is my will/src/hooks/useScrollPosition.js"],"sourcesContent":["import { useState, useEffect } from 'react';\n\nexport const useScrollPosition = () => {\n  const [scrollPosition, setScrollPosition] = useState(0);\n  const [isScrolled, setIsScrolled] = useState(false);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      const position = window.scrollY;\n      setScrollPosition(position);\n      setIsScrolled(position > 50);\n    };\n\n    window.addEventListener('scroll', handleScroll, { passive: true });\n    handleScroll();\n\n    return () => window.removeEventListener('scroll', handleScroll);\n  }, []);\n\n  return { scrollPosition, isScrolled };\n};\n\nexport default useScrollPosition;\n"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAE3C,MAAO,MAAM,CAAAC,iBAAiB,CAAGA,CAAA,GAAM,CACrC,KAAM,CAACC,cAAc,CAAEC,iBAAiB,CAAC,CAAGJ,QAAQ,CAAC,CAAC,CAAC,CACvD,KAAM,CAACK,UAAU,CAAEC,aAAa,CAAC,CAAGN,QAAQ,CAAC,KAAK,CAAC,CAEnDC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAM,YAAY,CAAGA,CAAA,GAAM,CACzB,KAAM,CAAAC,QAAQ,CAAGC,MAAM,CAACC,OAAO,CAC/BN,iBAAiB,CAACI,QAAQ,CAAC,CAC3BF,aAAa,CAACE,QAAQ,CAAG,EAAE,CAAC,CAC9B,CAAC,CAEDC,MAAM,CAACE,gBAAgB,CAAC,QAAQ,CAAEJ,YAAY,CAAE,CAA