{"ast":null,"code":"import gsap from'gsap';import{ScrollTrigger}from'gsap/ScrollTrigger';gsap.registerPlugin(ScrollTrigger);gsap.defaults({ease:'expo.out',duration:1});const prefersReducedMotion=window.matchMedia('(prefers-reduced-motion: reduce)').matches;if(prefersReducedMotion){gsap.globalTimeline.timeScale(20);}window.addEventListener('load',()=>ScrollTrigger.refresh());export{gsap,ScrollTrigger};","map":{"version":3,"names":["gsap","ScrollTrigger","registerPlugin","defaults","ease","duration","prefersReducedMotion","window","matchMedia","matches","globalTimeline","timeScale","addEventListener","refresh"],"sources":["/Users/zackyviriot/mgt-fashion/MGT SITES/Where is my will/src/lib/gsap.js"],"sourcesContent":["import gsap from 'gsap';\nimport { ScrollTrigger } from 'gsap/ScrollTrigger';\n\ngsap.registerPlugin(ScrollTrigger);\n\ngsap.defaults({\n  ease: 'expo.out',\n  duration: 1,\n});\n\nconst prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;\nif (prefersReducedMotion) {\n  gsap.globalTimeline.timeScale(20);\n}\n\nwindow.addEventListener('load', () => ScrollTrigger.refresh());\n\nexport { gsap, ScrollTrigger };\n"],"mappings":"AAAA,MAAO,CAAAA,IAAI,KAAM,MAAM,CACvB,OAASC,aAAa,KAAQ,oBAAoB,CAElDD,IAAI,CAACE,cAAc,CAACD,aAAa,CAAC,CAElCD,IAAI,CAACG,QAAQ,CAAC,CACZC,IAAI,CAAE,UAAU,CAChBC,QAAQ,CAAE,CACZ,CAAC,CAAC,CAEF,KAAM,CAAAC,oBAAoB,CAAGC,MAAM,CAACC,UAAU,CAAC,kCAAkC,CAAC,CAACC,OAAO,CAC1F,GAAIH,oBAAoB,CAAE,CACxBN,IAAI,CAACU,cAAc,CAACC,SAAS,CAAC,EAAE,CAAC,CACnC,CAEAJ,MAAM,CAACK,gBAAgB,CAAC,MAAM,CAAE,IAAMX,aAAa,CAACY,OAAO,CAAC,CAAC,CAAC,CAE9D,OAASb,IAAI,CAAEC,aAAa","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}